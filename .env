# Environment
ENV=development
DEBUG=false

# Database
DATABASE_URL=sqlite:///./cw_trading.db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Market
RISK_FREE_RATE=0.05
TRADING_DAYS=252
DEFAULT_VOL=0.30

# Risk Limits
MAX_DELTA=2000000
MAX_GAMMA=50000
MAX_VEGA=200000
MAX_POSITION_PER_CW=5000000
MAX_LOSS_DAILY=-5000000000

# Hedging Policy
DELTA_BAND=100000
HEDGE_RATIO=1.0
MIN_TRADE_SIZE=10000

# Paths
DATA_DIR=data
LOG_DIR=logs

# Alerting (configure as needed)
EMAIL_ENABLED=false
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=alerts@company.com
EMAIL_PASSWORD=your-app-password
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890
SMS_TO_NUMBER=+0987654321

# Broker API (configure for trade execution)
OCBS_ENABLED=false
OCBS_BASE_URL=https://api.ocbs.com
OCBS_API_KEY=your-ocbs-api-key
OCBS_API_SECRET=your-ocbs-api-secret
OCBS_TIMEOUT=30
RECONCILIATION_ENABLED=false
RECONCILIATION_INTERVAL_HOURS=24

# Security (for development - generate unique key for production)
ENCRYPTION_KEY=ZrSJ01uOIk1rEMRya97gzxcc8PkNYqFZ6Dh4pM7M3pA=
